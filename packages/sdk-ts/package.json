{
  "name": "@llm-judge/sdk",
  "version": "0.0.0",
  "description": "LLM Judge SDK for TypeScript — trace + score LLM apps",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.8.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.0",
    "vitest": "^2.1.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["llm", "evaluation", "observability", "judge", "tracing"]
}
