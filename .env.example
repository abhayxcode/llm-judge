# Copy to .env and fill in. .env is gitignored.

# Postgres
PG_HOST=localhost
PG_PORT=5432
PG_USER=judge
PG_PASSWORD=judge
PG_DB=judge

# ClickHouse
CH_HOST=localhost
CH_HTTP_PORT=8123
CH_NATIVE_PORT=9000
CH_USER=judge
CH_PASSWORD=judge
CH_DB=judge

# MinIO / S3
S3_ENDPOINT=http://localhost:9002
S3_REGION=us-east-1
S3_ACCESS_KEY=judge
S3_SECRET_KEY=judgejudge
S3_BUCKET_BLOBS=judge-blobs
S3_BUCKET_EXPORTS=judge-exports

# Redis
REDIS_URL=redis://localhost:6379/0

# Service ports (host)
INGEST_PORT=4318
API_PORT=4000
WEB_PORT=3000

# Judge LLM keys (server-side; not needed for SDK)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Default cloud judge (per SPEC §6)
JUDGE_DEFAULT_MODEL=claude-sonnet-4-6
JUDGE_FALLBACK_MODEL=gpt-4o-mini
